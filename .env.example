# Server Configuration
PORT=3333

# Mapbox Geocoding Token (Optional - Falls back to Open-Meteo if not set)
# Get a token at https://mapbox.com/
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Tomorrow.io API Key (Optional - Falls back to Open-Meteo if not set)
# Get a key at https://www.tomorrow.io/weather-api/
TOMORROW_IO_API_KEY=your_tomorrow_io_api_key_here
